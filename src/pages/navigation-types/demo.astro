 <!-- martrapp: Ported to Astro. Adopted script and links to demonstrate vtbags link-types-->

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Navigation Types Demo - Home</title>
    <link rel="stylesheet" href="/navigation-types/styles.css">
    <script is:inline src="/navigation-types/link-types.js"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
    <nav>
        <a data-vtbag-link-types="right/same/left" href="../demo/" class="active">Home</a>
        <a data-vtbag-link-types="left/same/right" href="../about/">About</a>
    </nav>
    <div class="monster-overview">
        <h1>Meet the monsters</h1>
        <p>Which one do you want to get to know better?</p>
        <ul class="boxes">
            <li><a data-vtbag-link-types="details" href="../detail/1/"><img src="../images/zorp.png" alt="Zorp" id="zorp"><span>Zorp</span></a></li>
            <li><a data-vtbag-link-types="details" href="../detail/2/"><img src="../images/fluffy.png" alt="Fluffy" id="fluffy"><span>Fluffy</span></a></li>
            <li><a data-vtbag-link-types="details" href="../detail/3/"><img src="../images/bloop.png" alt="Bloop" id="bloop"><span>Bloop</span></a></li>
            <li><a data-vtbag-link-types="details" href="../detail/4/"><img src="../images/spike.png" alt="Spike" id="spike"><span>Spike</span></a></li>
        </ul>
    </div>
</body>
</html>
